/* theme-default.wxss - 默认主题样式 */

page {
  --theme-background: #FFFFFF;
  --theme-card-bg: #F5F5F7;
  --theme-text-primary: #1D1D1F;
  --theme-text-secondary: #86868B;
  --theme-text-accent: #0071E3;
  --theme-border: #E5E5E5;
  --theme-shadow: 0 2px 12px rgba(0,0,0,0.06);
  --theme-shadow-card: 0 2px 12px rgba(0,0,0,0.06);
}

/* Apple 主题 - 极简纯净，摄影感强 */
.theme-apple {
  --theme-background: #FFFFFF;
  --theme-card-bg: #f5f5f7;
  --theme-text-primary: #1d1d1f;
  --theme-text-secondary: #7a7a7a;
  --theme-text-accent: #0066cc;
  --theme-border: #e0e0e0;
  --theme-shadow: 0 2px 12px rgba(0,0,0,0.06);
  --theme-shadow-card: 0 2px 12px rgba(0,0,0,0.06);
}

/* Notion 主题 - 温暖纸质感，文艺中性 */
.theme-notion {
  --theme-background: #ffffff;
  --theme-card-bg: #f6f5f4;
  --theme-text-primary: rgba(0,0,0,0.95);
  --theme-text-secondary: #a39e98;
  --theme-text-accent: #0075de;
  --theme-border: rgba(0,0,0,0.1);
  --theme-shadow: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.03);
  --theme-shadow-card: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.03);
}

/* Airbnb 主题 - 温暖珊瑚红，消费友好 */
.theme-airbnb {
  --theme-background: #ffffff;
  --theme-card-bg: #f7f7f7;
  --theme-text-primary: #222222;
  --theme-text-secondary: #6a6a6a;
  --theme-text-accent: #ff385c;
  --theme-border: #ebebeb;
  --theme-shadow: 0 2px 8px rgba(0,0,0,0.08);
  --theme-shadow-card: 0 4px 16px rgba(0,0,0,0.12);
}

/* Starbucks 主题 - 咖啡馆温暖感，奶油绿调 */
.theme-starbucks {
  --theme-background: #f2f0eb;
  --theme-card-bg: #edebe9;
  --theme-text-primary: rgba(0,0,0,0.87);
  --theme-text-secondary: rgba(0,0,0,0.58);
  --theme-text-accent: #00754a;
  --theme-border: #dddddd;
  --theme-shadow: 0 2px 8px rgba(0,0,0,0.10);
  --theme-shadow-card: 0 4px 12px rgba(0,0,0,0.14);
}