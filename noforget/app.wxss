/* noforget/app.wxss - 全局样式 + CSS变量 + 动效系统 */
/* 遵循 UI/UX Pro Max 精细化标准 */
/* 关键词：Soft UI Evolution（柔和UI进化版） + Minimalism */

@import 'theme-default.wxss';

/* ===== 动态主题注入区（由 JS setData 注入） ===== */
/*
 * --theme-accent:           主题强调色
 * --theme-accent-rgb:       RGB分离（供rgba()使用）
 * --theme-accent-light:     10%透明强调色
 * --theme-text-primary:     主文字色
 * --theme-text-secondary:   次文字色
 * --theme-text-accent:      强调文字色（=accent）
 * --theme-background:       页面背景色
 * --theme-card-bg:          卡片背景色
 * --theme-border:           边框色
 * --theme-shadow:           轻阴影（通用）
 * --theme-shadow-card:      卡片阴影（更重）
 * --theme-radius-card:      卡片圆角
 * --theme-radius-btn:       按钮圆角
 * --theme-icon-color:       图标颜色
 * --theme-duration-micro:   微交互时长（150ms）
 * --theme-ease-out-quart:  退出缓出曲线
 */

/* ===== 全局基础 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: var(--theme-background);
  color: var(--theme-text-primary);
  font-size: 15px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  /* 触控反馈优化（UX: Touch Target 44x44px） */
  touch-action: manipulation;
}

/* ===== 通用卡片 ===== */
/* UX: Layout - Content Jumping prevention, aspect-ratio reserved */
.card {
  background: var(--theme-card-bg);
  border-radius: var(--theme-radius-card, 16px);
  box-shadow: var(--theme-shadow-card);
  overflow: hidden;
  /* UX: Transform Performance - 动画只改 transform/opacity */
  transition:
    transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    box-shadow var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    opacity var(--theme-duration-micro, 150ms) ease;
}

.card:active {
  /* UX: Animation - 按下反馈弹性 scale */
  transform: scale(0.97);
}

/* UX: prefers-reduced-motion 降级处理 */
@media (prefers-reduced-motion: reduce) {
  .card:active {
    transform: none;
  }
}

/* ===== 通用按钮 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--theme-radius-btn, 12px);
  min-height: 44px;    /* UX: Touch Target ≥44px */
  min-width: 44px;
  padding: 10px 20px;
  font-size: 15px;
  font-weight: 600;
  color: #ffffff;
  background: var(--theme-accent);
  border: none;
  cursor: pointer;     /* UX: cursor-pointer on clickable */
  outline: none;
  transition:
    transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    box-shadow var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    background var(--theme-duration-micro, 150ms) ease;
  /* UX: No bounce/elastic - cubic-bezier is smooth */
}

.btn:active {
  transform: scale(0.93) translateY(1px);
  /* UX: 视觉下沉感 + 弹性回弹 */
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}

.btn-ghost {
  background: transparent;
  color: var(--theme-text-secondary);
  border: 1.5px solid var(--theme-border);
}

/* ===== 分割线 ===== */
.divider {
  width: 50px;
  height: 1px;
  background: var(--theme-border);
  opacity: 0.4;
  margin: 20px auto;
}

/* ===== 底部安全区 ===== */
/* UX: Layout - Fixed Positioning accounts for safe area */
.safe-area-bottom {
  padding-bottom: calc(44px + env(safe-area-inset-bottom, 20px));
}

/* ===== 蒙版层 ===== */
/* UX: Z-Index Management - 明确层级 */
/* z-index scale: modal(500) > overlay(300) > card(100) > base(1) */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 300;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

/* ===== 微交互：涟漪效果（按需启用） ===== */
/* 触摸时产生 material design 涟漪 */
/* 注意：小程序无 CSS 涟漪，用 transform scale 代替 */
