/* ===== 文字截断复用类 ===== */
.truncate {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ===== 焦点状态（无障碍：键盘导航） ===== */
/* UX: Focus states visible for keyboard nav */
.focus-ring:focus-visible {
  outline: 2px solid var(--theme-accent);
  outline-offset: 2px;
}
