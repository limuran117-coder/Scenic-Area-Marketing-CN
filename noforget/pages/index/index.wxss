/* pages/index/index.wxss - 首页样式 */

.container {
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ===== 顶部导航 ===== */
.nav-bar {
  padding: 0 24px 10px 24px;
  position: sticky;
  top: 0;
  z-index: 100;
  background: inherit;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-icon-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--theme-card-bg);
  box-shadow: var(--theme-shadow);
  transition: transform var(--duration-micro, 150ms) var(--ease-out-quart, ease-out),
              box-shadow var(--duration-micro, 150ms) var(--ease-out-quart, ease-out);
}

.nav-icon-btn:active {
  transform: scale(0.9);
}

.nav-icon-theme {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    #0066cc 0deg, #0066cc 90deg,
    #2385e2 90deg, #2385e2 180deg,
    #ff385c 180deg, #ff385c 270deg,
    #1E3932 270deg, #1E3932 360deg
  );
}

.nav-icon-mine {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 2px solid var(--theme-text-accent);
}

.nav-title {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.5px;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
  gap: 10px;
}

.empty-icon { font-size: 52px; opacity: 0.55; }
.empty-title { font-size: 20px; font-weight: 600; }
.empty-desc { font-size: 14px; text-align: center; max-width: 260px; line-height: 1.5; }

.empty-add-btn {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--theme-text-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 18px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.22);
}

.empty-add-btn text {
  color: #fff;
  font-size: 28px;
  font-weight: 300;
}

/* ===== 列表 ===== */
.list-scroll {
  padding: 0 16px 100px 16px;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* ===== 卡片通用 ===== */
.countdown-card {
  border-radius: var(--theme-radius-card, 18px);
  overflow: hidden;
  position: relative;
  background: var(--theme-card-bg);
  box-shadow: var(--theme-shadow-card);
  transition: transform var(--duration-state, 250ms) var(--ease-out-quart, ease-out),
              box-shadow var(--duration-state, 250ms) var(--ease-out-quart, ease-out);
}

.countdown-card:active {
  transform: scale(0.97);
}

/* ===== 有封面时的卡片 ===== */
.card-cover {
  width: 100%;
  height: 160px;
  position: relative;
  overflow: hidden;
}

.card-cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 全屏蒙版：渐变暗色，让白色文字清晰 */
.card-cover-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.08) 0%,
    rgba(0,0,0,0.42) 55%,
    rgba(0,0,0,0.62) 100%
  );
}

/* 左上角分类标签 */
.card-cover-tag {
  position: absolute;
  top: 10px;
  left: 10px;
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(255,255,255,0.18);
  border-radius: 20px;
  padding: 3px 9px 3px 7px;
  backdrop-filter: blur(8px);
}

.card-cover-tag-icon { font-size: 10px; }
.card-cover-tag-name { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.9); }

/* 右上角分享按钮 */
.card-share-btn {
  position: absolute;
  top: 10px;
  right: 10px;
}

.share-icon {
  font-size: 12px;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.18);
  border-radius: 50%;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(8px);
}

/* 底部文字压图区 */
.card-cover-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 16px 14px 16px;
}

.card-cover-days {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 2px;
}

.cover-days-num {
  font-size: 52px;
  font-weight: 200;
  line-height: 0.9;
  letter-spacing: -4px;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 2px 12px rgba(0,0,0,0.25);
}

.cover-days-label {
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.65);
  margin-top: 6px;
}

.card-cover-title {
  font-size: 15px;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2px 10px rgba(0,0,0,0.35);
  margin-bottom: 2px;
}

.card-cover-date {
  font-size: 11px;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.5px;
}

/* ===== 无封面时的紧凑卡片 ===== */
.card-no-cover {
  padding: 14px 14px 14px 14px;
}

.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.card-category-tag {
  display: flex;
  align-items: center;
  gap: 5px;
}

.card-category-icon { font-size: 12px; }
.card-category-name { font-size: 11px; font-weight: 500; }

/* 左数字右信息的行布局 */
.card-main-row {
  display: flex;
  align-items: center;
  gap: 14px;
}

.card-days-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 64px;
}

.card-days-num {
  font-size: 44px;
  font-weight: 200;
  line-height: 1;
  letter-spacing: -3px;
  font-variant-numeric: tabular-nums;
}

.card-days-label {
  font-size: 10px;
  letter-spacing: 2px;
  margin-top: 4px;
}

.card-info-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3px;
  min-width: 0;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-date {
  font-size: 12px;
}

.card-detail {
  font-size: 11px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 底部悬浮添加按钮 ===== */
.bottom-add-btn {
  position: fixed;
  bottom: 28px;
  right: 22px;
  z-index: 200;
}

.bottom-add-circle {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--theme-shadow-card);
  transition: transform var(--duration-micro, 150ms) var(--ease-out-quart, ease-out);
}

.bottom-add-circle text {
  color: #fff;
  font-size: 26px;
  font-weight: 300;
  line-height: 1;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 20px 0 60px 0;
  font-size: 12px;
}

/* ===== 主题选择器 ===== */
.theme-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.theme-picker-sheet {
  width: 100%;
  max-width: 500px;
  border-radius: 20px 20px 0 0;
  padding: 28px 20px 48px 20px;
}

.theme-picker-title {
  font-size: 17px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24px;
}

.theme-options {
  display: flex;
  gap: 16px;
  justify-content: center;
}

.theme-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.theme-option.active .theme-name {
  font-weight: 700;
}

.theme-preview {
  width: 68px;
  height: 68px;
  border-radius: var(--theme-radius-card, 16px);
  border: 2px solid transparent;
  transition: border-color 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-option.active .theme-preview {
  border-color: var(--theme-text-accent);
}

/* 各主题预览块 */
.apple-preview { background: #ffffff; border: 1px solid #e5e5e5; position: relative; }
.apple-preview::after { content: ''; width: 20px; height: 20px; border-radius: 50%; background: #0066cc; box-shadow: 0 2px 8px rgba(0,102,204,0.4); }

.notion-preview { background: #ffffff; border: 1px solid rgba(0,0,0,0.08); position: relative; }
.notion-preview::after { content: ''; width: 18px; height: 18px; border-radius: 5px; background: #2385e2; transform: rotate(-4deg); box-shadow: 0 1px 4px rgba(35,133,226,0.3); }

.airbnb-preview { background: #fff5f6; border: 1px solid #ffdfe3; position: relative; }
.airbnb-preview::after { content: ''; width: 20px; height: 20px; border-radius: 50%; background: #ff385c; box-shadow: 0 2px 8px rgba(255,56,92,0.4); }

.starbucks-preview { background: #f7f5f0; border: 1px solid #e8e2da; position: relative; }
.starbucks-preview::after { content: ''; width: 20px; height: 20px; border-radius: 50%; background: #1E3932; box-shadow: 0 2px 8px rgba(30,57,50,0.4); }

.theme-name { font-size: 12px; font-weight: 500; }
.theme-picker-cancel { margin-top: 24px; text-align: center; padding: 12px; font-size: 14px; }