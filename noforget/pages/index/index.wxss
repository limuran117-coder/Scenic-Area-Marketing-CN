/* pages/index/index.wxss - 首页样式 */

.container {
  min-height: 100vh;
  padding-top: 12px;           /* 整体下移，不贴顶 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ===== 顶部导航 ===== */
.nav-bar {
  padding: 12px 24px 8px 24px;   /* 顶栏留出灵动岛空间 */
  position: sticky;
  top: 0;
  z-index: 100;
  background: inherit;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-icon-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--theme-card-bg);
  box-shadow: var(--theme-shadow);
  transition: transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out),
              box-shadow var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out);
}

.nav-icon-btn:active {
  transform: scale(0.9);
}

.nav-icon-theme {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    #0066cc 0deg, #0066cc 90deg,
    #2385e2 90deg, #2385e2 180deg,
    #ff385c 180deg, #ff385c 270deg,
    #1E3932 270deg, #1E3932 360deg
  );
}

.nav-icon-mine {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 2px solid var(--theme-text-accent);
}

.nav-title {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.5px;
}

/* 灵动岛下方居中 Logo */
.nav-logo-area {
  display: flex;
  justify-content: center;
  padding: 6px 0 2px 0;        /* logo与灵动岛、与标题栏的间距 */
}
.nav-logo-img {
  width: 48px;
  height: 48px;
}

/* 标题区 */
.nav-title-area {
  display: flex;
  justify-content: center;
  padding: 2px 0 0 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
  gap: 10px;
}

.empty-icon { font-size: 52px; opacity: 0.55; }
.empty-title { font-size: 20px; font-weight: 600; }
.empty-desc { font-size: 14px; text-align: center; max-width: 260px; line-height: 1.5; }

.empty-add-btn {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--theme-text-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 18px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.22);
}

.empty-add-btn text {
  color: #fff;
  font-size: 28px;
  font-weight: 300;
}

/* ===== 列表 ===== */
.list-scroll {
  padding: 0 16px 100px 16px;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* ===== 卡片通用 ===== */
.countdown-card {
  border-radius: var(--theme-radius-card, 18px);
  overflow: hidden;
  position: relative;
  background: var(--theme-card-bg);
  box-shadow: var(--theme-shadow-card);
  transition: transform var(--theme-duration-micro, 250ms) var(--theme-ease-out-quart, ease-out),
              box-shadow var(--theme-duration-micro, 250ms) var(--theme-ease-out-quart, ease-out);
}

.countdown-card:active {
  transform: scale(0.97);
}

/* ===== 有封面时的卡片 ===== */
.card-cover {
  width: 100%;
  height: 160px;
  position: relative;
  overflow: hidden;
}

.card-cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 全屏蒙版：渐变暗色，让白色文字清晰 */
.card-cover-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.08) 0%,
    rgba(0,0,0,0.42) 55%,
    rgba(0,0,0,0.62) 100%
  );
}

/* 左上角分类标签 */
.card-cover-tag {
  position: absolute;
  top: 10px;
  left: 10px;
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(255,255,255,0.18);
  border-radius: 20px;
  padding: 3px 9px 3px 7px;
  backdrop-filter: blur(8px);
}

.card-cover-tag-icon { font-size: 10px; }
.card-cover-tag-name { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.9); }

/* 右上角分享按钮 */
.card-share-btn {
  position: absolute;
  top: 10px;
  right: 10px;
}

.share-icon {
  font-size: 12px;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.18);
  border-radius: 50%;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(8px);
}

/* 底部文字压图区 */
.card-cover-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 16px 14px 16px;
}

.card-cover-days {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 2px;
}

.cover-days-num {
  font-size: 52px;
  font-weight: 200;
  line-height: 0.9;
  letter-spacing: -4px;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 2px 12px rgba(0,0,0,0.25);
}

.cover-days-label {
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.65);
  margin-top: 6px;
}

.card-cover-title {
  font-size: 15px;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2px 10px rgba(0,0,0,0.35);
  margin-bottom: 2px;
}

.card-cover-date {
  font-size: 11px;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.5px;
}

/* ===== 无封面卡片（重新设计：数字左+信息右） ===== */
.card-no-cover {
  padding: 14px 20px 16px 20px; /* 增大左右边距 */
}

/* 顶栏：分类标签左 + 分享右 */
.no-cover-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.card-category-tag {
  display: flex;
  align-items: center;
  gap: 6px;
}

.card-category-icon {
  width: 18px;
  height: 18px;
  /* UX: 固定尺寸防抖动 */
}

.card-category-name {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.3px;
}

/* 主体：左侧大数字 + 右侧详情 */
.no-cover-body {
  display: flex;
  align-items: flex-start;
  gap: 10px;                   /* 收紧左右间距 */
  padding-top: 4px;            /* 内容往下一点 */
}

/* 左侧天数区 */
.no-cover-days {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  min-width: 72px;
  padding-top: 4px;
}

.no-cover-days-num {
  font-size: 52px;
  font-weight: 200;
  line-height: 0.9;
  letter-spacing: -4px;
  font-variant-numeric: tabular-nums;
  /* 衬线字体，数字更有日历刻度质感 */
  font-family: Georgia, 'Times New Roman', 'Songti SC', serif;
}

.no-cover-days-label {
  font-size: 12px;
  letter-spacing: 1px;
  margin-top: 6px;
  color: var(--theme-text-secondary);
}

/* 时分秒小字 */
.no-cover-hms {
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 0.5px;
  font-variant-numeric: tabular-nums;
  margin-top: 2px;
}

/* 右侧信息区 */
.no-cover-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  min-width: 0;
  padding-top: 4px;
  text-align: left;
}

.no-cover-title {
  font-size: 20px;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.2;
}

.no-cover-date {
  font-size: 14px;
  letter-spacing: 0.5px;
  opacity: 0.65;
}

.no-cover-elapsed {
  font-size: 13px;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 2px;
}

/* 天数+标签行 */
.no-cover-days-row {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

/* ===== 底部悬浮添加按钮 ===== */
.bottom-add-btn {
  position: fixed;
  bottom: 28px;
  right: 22px;
  z-index: 200;
}

.bottom-add-circle {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--theme-shadow-card);
  transition: transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out);
}

.bottom-add-circle text {
  color: #fff;
  font-size: 26px;
  font-weight: 300;
  line-height: 1;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 20px 0 60px 0;
  font-size: 12px;
}

/* ===== 主题选择器 ===== */
.theme-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.theme-picker-sheet {
  width: 100%;
  max-width: 500px;
  border-radius: 20px 20px 0 0;
  padding: 28px 20px 48px 20px;
}

.theme-picker-title {
  font-size: 17px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24px;
}

.theme-options {
  display: flex;
  gap: 16px;
  justify-content: center;
}

.theme-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.theme-option.active .theme-name {
  font-weight: 700;
}

.theme-preview {
  width: 68px;
  height: 68px;
  border-radius: var(--theme-radius-card, 16px);
  border: 2px solid transparent;
  transition: border-color 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-option.active .theme-preview {
  border-color: var(--theme-text-accent);
}

/* 各主题预览块 */
.apple-preview { background: #ffffff; border: 1px solid #e5e5e5; position: relative; }
.apple-preview::after { content: ''; width: 20px; height: 20px; border-radius: 50%; background: #0066cc; box-shadow: 0 2px 8px rgba(0,102,204,0.4); }

.notion-preview { background: #ffffff; border: 1px solid rgba(0,0,0,0.08); position: relative; }
.notion-preview::after { content: ''; width: 18px; height: 18px; border-radius: 5px; background: #2385e2; transform: rotate(-4deg); box-shadow: 0 1px 4px rgba(35,133,226,0.3); }

.airbnb-preview { background: #fff5f6; border: 1px solid #ffdfe3; position: relative; }
.airbnb-preview::after { content: ''; width: 20px; height: 20px; border-radius: 50%; background: #ff385c; box-shadow: 0 2px 8px rgba(255,56,92,0.4); }

.starbucks-preview { background: #f7f5f0; border: 1px solid #e8e2da; position: relative; }
.starbucks-preview::after { content: ''; width: 20px; height: 20px; border-radius: 50%; background: #1E3932; box-shadow: 0 2px 8px rgba(30,57,50,0.4); }

.theme-name { font-size: 12px; font-weight: 500; }
.theme-picker-cancel { margin-top: 24px; text-align: center; padding: 12px; font-size: 14px; }
/* ============================================================
   Phase 2 补充：5主题分类独立视觉
   首页卡片按分类有不同的数字颜色和氛围点缀
   ============================================================ */

/* ── 生日 ── 暖金色数字 + 琥珀底部渐变 ── */
.countdown-card.cat-birthday {
  border-bottom: 3px solid rgba(212,160,23,0.45);
}

.countdown-card.cat-birthday .no-cover-days-num {
  color: #D4A017 !important;
  font-family: Georgia, 'Times New Roman', serif;
}

.countdown-card.cat-birthday .no-cover-days-label,
.countdown-card.cat-birthday .no-cover-hms {
  color: rgba(212,160,23,0.55) !important;
}

.countdown-card.cat-birthday .no-cover-date {
  color: rgba(212,160,23,0.55) !important;
}

.countdown-card.cat-birthday .card-category-name {
  color: #D4A017 !important;
}

.countdown-card.cat-birthday .no-cover-elapsed {
  color: #C09010 !important;
}

/* ── 恋爱 ── 玫瑰粉数字 + 粉紫底部渐变 ── */
.countdown-card.cat-love {
  border-bottom: 3px solid rgba(232,113,154,0.4);
}

.countdown-card.cat-love .no-cover-days-num {
  color: #E8719A !important;
  font-family: Georgia, 'Times New Roman', serif;
}

.countdown-card.cat-love .no-cover-days-label,
.countdown-card.cat-love .no-cover-hms {
  color: rgba(232,113,154,0.5) !important;
}

.countdown-card.cat-love .no-cover-date {
  color: rgba(232,113,154,0.55) !important;
}

.countdown-card.cat-love .card-category-name {
  color: #E8719A !important;
}

.countdown-card.cat-love .no-cover-elapsed {
  color: #D4608A !important;
}

/* ── 结婚 ── 香槟金数字 + 优雅分隔线 ── */
.countdown-card.cat-wedding {
  border-bottom: 3px solid rgba(201,169,110,0.5);
}

.countdown-card.cat-wedding .no-cover-days-num {
  color: #C9A96E !important;
  font-family: Georgia, 'Times New Roman', serif;
}

.countdown-card.cat-wedding .no-cover-days-label,
.countdown-card.cat-wedding .no-cover-hms {
  color: rgba(201,169,110,0.6) !important;
}

.countdown-card.cat-wedding .no-cover-date {
  color: rgba(139,115,85,0.7) !important;
}

.countdown-card.cat-wedding .card-category-name {
  color: #C9A96E !important;
}

.countdown-card.cat-wedding .no-cover-elapsed {
  color: #8B7355 !important;
}

/* ── 忌日 ── 银紫数字 + 静谧分隔线 ── */
.countdown-card.cat-death {
  border-bottom: 3px solid rgba(144,144,176,0.35);
}

.countdown-card.cat-death .no-cover-days-num {
  color: #9090B0 !important;
  font-family: Georgia, 'Times New Roman', serif;
}

.countdown-card.cat-death .no-cover-days-label,
.countdown-card.cat-death .no-cover-hms {
  color: rgba(144,144,176,0.55) !important;
}

.countdown-card.cat-death .no-cover-date {
  color: rgba(144,144,176,0.6) !important;
}

.countdown-card.cat-death .card-category-name {
  color: #9090B0 !important;
}

.countdown-card.cat-death .no-cover-elapsed {
  color: #7878A0 !important;
}

/* ── 宠物生日 ── 焦糖棕数字 + 温暖分隔线 ── */
.countdown-card.cat-pet_birthday {
  border-bottom: 3px solid rgba(196,120,48,0.4);
}

.countdown-card.cat-pet_birthday .no-cover-days-num {
  color: #C47830 !important;
  font-family: Georgia, 'Times New Roman', serif;
}

.countdown-card.cat-pet_birthday .no-cover-days-label,
.countdown-card.cat-pet_birthday .no-cover-hms {
  color: rgba(196,120,48,0.55) !important;
}

.countdown-card.cat-pet_birthday .no-cover-date {
  color: rgba(196,120,48,0.6) !important;
}

.countdown-card.cat-pet_birthday .card-category-name {
  color: #C47830 !important;
}

.countdown-card.cat-pet_birthday .no-cover-elapsed {
  color: #A06820 !important;
}

/* ============================================================
   Phase 4：每日温馨话Banner
   ============================================================ */
.daily-banner {
  margin: 12px 16px 8px 16px;
  border-radius: 16px;
  padding: 16px 20px 14px 20px;
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
  min-height: 56px;
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.12);
  transition: opacity 0.3s, transform 0.3s;
  cursor: pointer;
}

.banner-show {
  opacity: 1;
  transform: translateY(0);
}

.banner-hide {
  opacity: 0;
  transform: translateY(-8px);
  pointer-events: none;
}

.banner-emoji {
  font-size: 22px;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 1px;
}

.banner-text {
  flex: 1;
  font-size: 15px;
  font-weight: 500;
  line-height: 1.5;
  letter-spacing: 0.2px;
}

.banner-close {
  font-size: 12px;
  color: rgba(255,255,255,0.45);
  flex-shrink: 0;
  padding: 4px;
  margin-top: -2px;
}

.banner-label {
  position: absolute;
  top: 6px;
  right: 14px;
  font-size: 10px;
  letter-spacing: 0.8px;
  opacity: 0.4;
  text-transform: uppercase;
  font-weight: 500;
}

/* ── Banner 各主题配色 ── */
/* 通用默认Banner */
.daily-banner {
  background: linear-gradient(135deg, rgba(40,20,10,0.88) 0%, rgba(30,15,5,0.92) 100%);
  border-color: rgba(212,160,23,0.25);
}

.daily-banner .banner-text { color: rgba(255,228,181,0.9); }
.daily-banner .banner-close { color: rgba(255,228,181,0.4); }
.daily-banner .banner-label { color: rgba(212,160,23,0.5); }

/* ── 生日Banner ── */
.daily-banner.cat-birthday {
  background: linear-gradient(135deg, rgba(30,15,0,0.9) 0%, rgba(40,20,5,0.92) 100%);
  border-color: rgba(212,160,23,0.3);
}
.daily-banner.cat-birthday .banner-text { color: rgba(255,228,181,0.92); }
.daily-banner.cat-birthday .banner-label { color: rgba(212,160,23,0.5); }

/* ── 恋爱Banner ── */
.daily-banner.cat-love {
  background: linear-gradient(135deg, rgba(35,8,20,0.9) 0%, rgba(25,5,15,0.92) 100%);
  border-color: rgba(232,113,154,0.3);
}
.daily-banner.cat-love .banner-text { color: rgba(255,200,215,0.9); }
.daily-banner.cat-love .banner-label { color: rgba(232,113,154,0.5); }

/* ── 忌日Banner ── */
.daily-banner.cat-death {
  background: linear-gradient(135deg, rgba(10,10,28,0.92) 0%, rgba(8,8,22,0.95) 100%);
  border-color: rgba(144,144,176,0.25);
}
.daily-banner.cat-death .banner-text { color: rgba(200,200,220,0.85); }
.daily-banner.cat-death .banner-label { color: rgba(144,144,176,0.5); }

/* ── 宠物Banner ── */
.daily-banner.cat-pet_birthday {
  background: linear-gradient(135deg, rgba(50,30,10,0.88) 0%, rgba(40,25,5,0.9) 100%);
  border-color: rgba(196,120,48,0.3);
}
.daily-banner.cat-pet_birthday .banner-text { color: rgba(255,220,180,0.9); }
.daily-banner.cat-pet_birthday .banner-label { color: rgba(196,120,48,0.5); }

/* ── 结婚Banner（浅色） ── */
.daily-banner.cat-wedding {
  background: linear-gradient(135deg, rgba(255,250,240,0.95) 0%, rgba(250,245,235,0.97) 100%);
  border-color: rgba(201,169,110,0.35);
}
.daily-banner.cat-wedding .banner-text { color: rgba(90,70,40,0.9); }
.daily-banner.cat-wedding .banner-close { color: rgba(139,115,85,0.5); }
.daily-banner.cat-wedding .banner-label { color: rgba(201,169,110,0.6); }
