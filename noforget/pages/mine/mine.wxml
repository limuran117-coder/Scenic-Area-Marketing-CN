<!-- pages/mine/mine.wxml - 我的页面 -->
<view class="container" style="background: {{theme.background}};">
  <!-- 顶部导航 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title" style="color: {{theme.textPrimary}};">我的</text>
    </view>
  </view>

  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-card" style="background: {{theme.cardBg}}; box-shadow: {{theme.shadow}};">
      <view class="user-info" wx:if="{{hasLogin}}">
        <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-detail">
          <text class="nickname" style="color: {{theme.textPrimary}};">{{userInfo.nickName}}</text>
          <text class="user-desc" style="color: {{theme.textSecondary}};">记录每一个重要时刻</text>
        </view>
      </view>
      <view class="user-info not-login" wx:else bindtap="doLogin">
        <view class="avatar-placeholder">
          <text>👤</text>
        </view>
        <view class="user-detail">
          <text class="nickname" style="color: {{theme.textPrimary}};">点击登录</text>
          <text class="user-desc" style="color: {{theme.textSecondary}};">登录后同步你的数据</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section">
    <view class="stats-card" style="background: {{theme.cardBg}}; box-shadow: {{theme.shadow}};">
      <view class="stat-item">
        <text class="stat-number" style="color: {{theme.textPrimary}};">{{stats.total}}</text>
        <text class="stat-label" style="color: {{theme.textSecondary}};">总记录</text>
      </view>
      <view class="stat-divider" style="background: {{theme.border}};"></view>
      <view class="stat-item">
        <text class="stat-number" style="color: {{theme.textPrimary}};">{{stats.upcoming}}</text>
        <text class="stat-label" style="color: {{theme.textSecondary}};">即将到来</text>
      </view>
      <view class="stat-divider" style="background: {{theme.border}};"></view>
      <view class="stat-item">
        <text class="stat-number" style="color: {{theme.textPrimary}};">{{stats.past}}</text>
        <text class="stat-label" style="color: {{theme.textSecondary}};">已过纪念</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="switchTheme">
        <text class="menu-icon">🎨</text>
        <text class="menu-text">主题设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" style="border-bottom: 1px solid {{theme.border}};">
        <text class="menu-icon">🔔</text>
        <text class="menu-text">提醒设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="exportData">
        <text class="menu-icon">📤</text>
        <text class="menu-text">导出数据</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" style="border-bottom: 1px solid {{theme.border}};">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于 No Forget</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="contactUs">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部版本 -->
  <view class="footer">
    <text style="color: {{theme.textSecondary}};">No Forget v1.0.0</text>
    <text style="color: {{theme.textSecondary}};">记住每一个重要时刻 ❤️</text>
  </view>
</view>
