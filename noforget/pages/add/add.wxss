/* pages/add/add.wxss - 添加页面样式 */

.container {
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  padding-bottom: 100px;
}

/* 顶部导航 */
.nav-bar {
  padding: 0 20px 16px 20px;
  position: sticky;
  top: 0;
  z-index: 100;
  background: inherit;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
}

.back-btn, .save-btn {
  padding: 8px 12px;
  min-width: 50px;
  border-radius: 8px;
}

.back-btn {
  text-align: left;
}

.save-btn {
  text-align: right;
  font-weight: 600;
  background: rgba(0, 0, 0, 0.05);
}

.save-btn-text {
  font-size: 16px;
}

/* 表单 */
.form {
  padding: 0 20px;
}

.form-item {
  margin-bottom: 32px;
}

.form-label {
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 12px;
  display: block;
}

.form-input {
  font-size: 17px;
  padding: 12px 0;
  width: 100%;
}

/* 日期选择器 */
.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  font-size: 17px;
}

/* 分类选择 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 8px;
  border-radius: 12px;
  border: 1px solid;
  transition: all 0.2s;
}

.category-item.active {
  background: rgba(0, 0, 0, 0.03);
}

.category-icon {
  font-size: 24px;
  margin-bottom: 4px;
}

.category-name {
  font-size: 11px;
  text-align: center;
}

/* 计时方向 */
.direction-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.direction-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px;
  border-radius: 12px;
  border: 1px solid;
  transition: all 0.2s;
}

.direction-item text:first-child {
  font-size: 15px;
  font-weight: 500;
  margin-bottom: 4px;
}

.direction-desc {
  font-size: 12px;
}

/* 计算方式说明 */
.calc-hint {
  margin-top: 16px;
  padding: 12px 16px;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 10px;
}

.hint-title {
  font-size: 12px;
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
}

.hint-text {
  font-size: 13px;
  line-height: 1.6;
}

/* 提醒选项 */
.remind-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.remind-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px 8px;
  border-radius: 8px;
  border: 1px solid;
  transition: all 0.2s;
}

.remind-item text {
  font-size: 12px;
}

/* 封面照片 */
.cover-picker {
  width: 100%;
}

.cover-image-wrapper {
  position: relative;
  width: 100%;
  height: 180px;
  border-radius: 12px;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  display: flex;
  justify-content: center;
}

.cover-change {
  font-size: 13px;
}

.cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.02);
}

.cover-add-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.cover-add-text {
  font-size: 15px;
  margin-bottom: 4px;
}

.cover-add-hint {
  font-size: 12px;
}

.cover-remove {
  text-align: center;
  padding: 12px;
  font-size: 13px;
  margin-top: 8px;
}

/* 预览区域 */
.preview-section {
  margin-top: 40px;
  padding-top: 32px;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
}

.preview-title {
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  display: block;
  margin-bottom: 16px;
}

.preview-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 24px;
  border-radius: 20px;
  overflow: hidden;
}

.preview-cover {
  width: 100%;
  height: 120px;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 16px;
}

.preview-cover image {
  width: 100%;
  height: 100%;
}

.preview-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.preview-days {
  font-size: 56px;
  font-weight: 200;
  letter-spacing: -2px;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.preview-label {
  font-size: 12px;
  letter-spacing: 2px;
  margin-top: 4px;
  margin-bottom: 12px;
}

.preview-name {
  font-size: 16px;
  font-weight: 500;
}

/* 底部按钮组 - 横排 */
.bottom-buttons {
  position: fixed;
  bottom: 40px;
  left: 20px;
  right: 20px;
  display: flex;
  gap: 12px;
}

.bottom-btn-primary {
  flex: 1;
  padding: 14px 16px;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bottom-btn-primary.full-width {
  flex: 1;
}

.bottom-btn-danger {
  width: 80px;
  padding: 14px 12px;
  border-radius: 12px;
  background: #FF3B30;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bottom-btn-danger.hide {
  display: none;
}

.btn-zh {
  font-size: 16px;
  font-weight: 600;
}

.btn-en {
  font-size: 11px;
  margin-top: 2px;
  letter-spacing: 0.5px;
}

/* 裁切弹层 */
.crop-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
  z-index: 9999;
  display: flex;
  flex-direction: column;
}

.crop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: rgba(0, 0, 0, 0.6);
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
}

.crop-cancel {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.7);
  padding: 8px 0;
}

.crop-title {
  font-size: 16px;
  font-weight: 600;
  color: #FFF;
}

.crop-confirm {
  font-size: 16px;
  font-weight: 600;
  color: #0071E3;
  padding: 8px 0;
}

.crop-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.crop-wrapper {
  width: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.crop-image {
  width: 100%;
  display: block;
}

/* 裁切框 - 固定高度，可拖动 */
.crop-frame {
  position: absolute;
  left: 0;
  right: 0;
  height: 240px;
  border-top: 1px solid rgba(255, 255, 255, 0.8);
  border-bottom: 1px solid rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
  background: transparent;
  z-index: 5;
  transition: none;
}

/* 半透明遮罩 */
.crop-mask-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 4;
  pointer-events: none;
}

.crop-mask-bottom {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 4;
  pointer-events: none;
}

/* 拖动提示 */
.crop-hint {
  position: absolute;
  bottom: 80px;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 6;
  opacity: 0.8;
}

/* 隐藏canvas */
.crop-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  opacity: 0;
}
