/* pages/add/add.wxss - 添加页面样式 */

.container {
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  padding-bottom: 120px;
}

/* ===== 顶部导航 ===== */
.nav-bar {
  padding: 0 20px 16px 20px;
  position: sticky;
  top: 0;
  z-index: 100;
  background: inherit;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
}

.back-btn {
  padding: 8px 12px;
  min-width: 50px;
}

/* ===== 表单 ===== */
.form {
  padding: 0 20px;
}

.form-item {
  margin-bottom: 30px;
}

.form-label {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 12px;
  display: block;
}

.form-input {
  font-size: 17px;
  padding: 12px 0;
  width: 100%;
  border-bottom: 1px solid var(--theme-border);
}

/* ===== 日期选择器 ===== */
.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  font-size: 17px;
}

/* ===== 分类选择 ===== */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;  /* UX: Touch Spacing ≥8px */
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14px 6px 10px 6px;
  border-radius: var(--theme-radius-card, 12px);
  border: 1.5px solid var(--theme-border);
  /* UX: Transform Performance - 动画只用 transform/opacity */
  transition:
    border-color var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out),
    background var(--theme-duration-micro, 150ms) ease,
    transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out);
  background: transparent;
  min-height: 80px;  /* 触控友好 */
}

/* UX: Active state - 当前选中项 */
.category-item.active {
  border-color: var(--theme-text-accent);
  background: var(--theme-accent-light, rgba(0,0,0,0.04));
}

/* UX: 按下弹性反馈 */
.category-item:active {
  transform: scale(0.93);
}

/* SVG 图标容器 */
.category-icon {
  width: 26px;
  height: 26px;
  margin-bottom: 6px;
  /* UX: 固定尺寸防抖动 */
}

.category-name {
  font-size: 11px;
  text-align: center;
  line-height: 1.2;
  color: var(--theme-text-secondary);
}

/* ===== 计时方向 ===== */
.direction-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.direction-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 12px;
  border-radius: var(--theme-radius-card, 12px);
  border: 1.5px solid;
  transition: all var(--theme-duration-micro, 250ms) var(--theme-ease-out-quart, ease-out);
}

.direction-item:active {
  transform: scale(0.97);
}

.direction-item text:first-child {
  font-size: 15px;
  font-weight: 500;
  margin-bottom: 4px;
}

.direction-desc {
  font-size: 11px;
}

/* ===== 计算方式说明 ===== */
.calc-hint {
  margin-top: 14px;
  padding: 12px 16px;
  background: rgba(0, 0, 0, 0.03);
  border-radius: var(--theme-radius-card, 12px);
}

.hint-title {
  font-size: 12px;
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
}

.hint-text {
  font-size: 13px;
  line-height: 1.6;
}

/* ===== 提醒选项 ===== */
.remind-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.remind-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px 6px;
  border-radius: var(--theme-radius-card, 12px);
  border: 1.5px solid;
  transition: all var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out);
}

.remind-item text {
  font-size: 12px;
}

/* ===== 封面照片 ===== */
.cover-picker {
  width: 100%;
}

.cover-image-wrapper {
  position: relative;
  width: 100%;
  height: 180px;
  border-radius: var(--theme-radius-card, 12px);
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  display: flex;
  justify-content: center;
}

.cover-change {
  font-size: 13px;
}

.cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  border-radius: var(--theme-radius-card, 12px);
  background: rgba(0, 0, 0, 0.02);
}

.cover-add-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.cover-add-text {
  font-size: 15px;
  margin-bottom: 4px;
}

.cover-add-hint {
  font-size: 12px;
}

.cover-remove {
  text-align: center;
  padding: 12px;
  font-size: 13px;
  margin-top: 8px;
}

/* ===== 预览区域 ===== */
.preview-section {
  margin-top: 40px;
  padding-top: 32px;
  border-top: 1px solid var(--theme-border);
}

.preview-title {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.8px;
  color: var(--theme-text-secondary);
  text-transform: uppercase;
  display: block;
  margin-bottom: 16px;
}

.preview-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 24px;
  border-radius: var(--theme-radius-card, 20px);
  overflow: hidden;
  background: var(--theme-card-bg);
  box-shadow: var(--theme-shadow-card);
}

.preview-cover {
  width: 100%;
  height: 120px;
  border-radius: var(--theme-radius-card, 12px);
  overflow: hidden;
  margin-bottom: 16px;
}

.preview-cover image {
  width: 100%;
  height: 100%;
}

.preview-icon-img {
  width: 36px;
  height: 36px;
  margin-bottom: 10px;
}

.preview-days {
  font-size: 56px;
  font-weight: 200;
  letter-spacing: -2px;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  color: var(--theme-text-primary);
  font-family: Georgia, 'Times New Roman', serif;
}

.preview-label {
  font-size: 12px;
  letter-spacing: 2px;
  margin-top: 4px;
  margin-bottom: 4px;
  color: var(--theme-text-secondary);
}

.preview-hms {
  font-size: 18px;
  font-weight: 300;
  letter-spacing: 1px;
  color: var(--theme-text-secondary);
  opacity: 0.7;
  font-variant-numeric: tabular-nums;
}

.preview-name {
  font-size: 16px;
  font-weight: 500;
  color: var(--theme-text-primary);
}

/* ===== 底部按钮组 ===== */
.bottom-buttons {
  position: fixed;
  bottom: 40px;
  left: 20px;
  right: 20px;
  display: flex;
  gap: 12px;
  padding-bottom: env(safe-area-inset-bottom, 0);
}

.bottom-btn-primary {
  flex: 1;
  padding: 15px 16px;
  border-radius: var(--theme-radius-btn, 50px);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out),
              box-shadow var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out);
  box-shadow: var(--theme-shadow-card);
}

.bottom-btn-primary:active {
  transform: scale(0.97);
}

.bottom-btn-primary.full-width {
  flex: 1;
}

.bottom-btn-danger {
  width: 80px;
  padding: 15px 12px;
  border-radius: var(--theme-radius-btn, 50px);
  background: #FF3B30;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4px 12px rgba(255,59,48,0.3);
}

.bottom-btn-danger:active {
  transform: scale(0.97);
}

.bottom-btn-danger.hide {
  display: none;
}

.btn-zh {
  font-size: 16px;
  font-weight: 600;
}

.btn-en {
  font-size: 11px;
  margin-top: 2px;
  letter-spacing: 0.5px;
}

/* ===== 裁切弹层 ===== */
.crop-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  /* UX: Z-Index Management - 层级规范 */
  z-index: 500;
  display: flex;
  flex-direction: column;
}

.crop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  padding-top: calc(16px + env(safe-area-inset-top, 0));
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(12px);
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  /* UX: 动效 - 进入 */
  animation: crop-header-in 250ms var(--theme-ease-out-quart, ease-out) both;
}

@keyframes crop-header-in {
  from { opacity: 0; transform: translateY(-10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.crop-cancel {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.7);
  padding: 8px 0;
  min-width: 50px;
  transition: color var(--theme-duration-micro, 150ms) ease;
}

.crop-cancel:active { color: rgba(255,255,255,1); }

.crop-title {
  font-size: 16px;
  font-weight: 600;
  color: #FFF;
}

.crop-confirm {
  font-size: 16px;
  font-weight: 600;
  /* UX: 硬编码颜色 → 主题强调色 */
  color: var(--theme-accent, #007AFF);
  padding: 8px 0;
  min-width: 50px;
  text-align: right;
  transition: transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, ease-out);
}

.crop-confirm:active { transform: scale(0.93); }

.crop-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.crop-wrapper {
  width: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  /* UX: 触控手势 - 允许垂直滚动但不触发外层滚动 */
  touch-action: pan-y;
}

.crop-image {
  width: 100%;
  display: block;
}

.crop-frame {
  position: absolute;
  left: 0;
  right: 0;
  height: 240px;
  border-top: 1.5px solid rgba(255, 255, 255, 0.9);
  border-bottom: 1.5px solid rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  background: transparent;
  z-index: 5;
  /* UX: 弹性感 - 用 box-shadow 表现光标位置 */
  box-shadow:
    0 2px 12px rgba(0,0,0,0.3) inset,
    0 -2px 12px rgba(0,0,0,0.3) inset;
  /* UX: 动画 - 拖动时边框略微高亮 */
  transition: box-shadow 100ms ease;
}

.crop-mask-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 4;
  pointer-events: none;
}

.crop-mask-bottom {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 4;
  pointer-events: none;
}

.crop-hint {
  position: absolute;
  bottom: 80px;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 6;
  opacity: 0.8;
}

.crop-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  opacity: 0;
}
