/* pages/detail/detail.wxss v2 - 5主题独立视觉系统
 *
 * 每个分类有独特的主视觉：
 *   🎂 birthday  → 暖琥珀 + 金色衬线数字
 *   💕 love      → 深玫瑰紫 + 粉光浪漫
 *   💒 wedding   → 纯白 + 香槟金典雅
 *   🙏 death     → 深空蓝 + 星光银紫
 *   🐾 pet_birthday → 暖奶油 + 焦糖棕温馨
 *
 * CSS变量命名规范: --cat-[主题]-[属性]
 */

/* ============================================================
   基础布局
   ============================================================ */
.detail-page {
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  position: relative;
}

/* ============================================================
   通用顶部导航
   ============================================================ */
.detail-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  padding: 0 20px 12px 20px;
}

.detail-nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-back-btn {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
}

.detail-back-arrow {
  font-size: 22px;
  /* 颜色由各主题覆盖 */
  transition: opacity 0.15s;
}

.detail-nav-logo {
  display: flex; align-items: center; justify-content: center;
}

.detail-nav-logo-img {
  height: 18px; width: auto;
  opacity: 0.7;
}

.detail-edit-btn {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
}

.detail-edit-text {
  font-size: 11px;
  letter-spacing: 0.5px;
}

/* ============================================================
   封面大卡片（通用）
   ============================================================ */
.detail-cover-block {
  width: 100%;
  height: 420px;
  position: relative;
  overflow: hidden;
}

.detail-cover-img {
  position: absolute;
  bottom: 0; left: 0;
  width: 100%;
  height: 520px;
  object-fit: cover;
}

.detail-cover-overlay {
  position: absolute;
  inset: 0;
  /* 由各主题覆盖颜色 */
  z-index: 1;
}

.detail-cover-fade-top {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 100px;
  z-index: 2;
  /* 由各主题覆盖 */
}

.detail-cover-top-right {
  position: absolute;
  top: calc(20px + env(safe-area-inset-top, 20px));
  right: 18px;
  z-index: 210;
}

.detail-cover-action-btn {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.22);
  backdrop-filter: blur(10px);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px;
  color: #ffffff;
}

.detail-cover-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24px 28px 24px;
}

.detail-cover-tag {
  display: flex;
  align-items: center;
  gap: 5px;
  border-radius: 20px;
  padding: 5px 12px 5px 10px;
  backdrop-filter: blur(8px);
  margin-bottom: 12px;
  /* 由各主题覆盖背景 */
}

.detail-cover-tag-name {
  font-size: 11px;
  font-weight: 600;
}

.detail-cover-number {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 8px;
}

.detail-cover-main-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.detail-cover-days {
  font-size: 100px;
  font-weight: 200;
  line-height: 0.9;
  letter-spacing: -6px;
  font-variant-numeric: tabular-nums;
  font-family: Georgia, 'Times New Roman', serif;
}

.detail-cover-days-label {
  font-size: 28px;
  font-weight: 300;
  padding-bottom: 4px;
}

.detail-cover-hms {
  font-size: 28px;
  font-weight: 200;
  letter-spacing: 2px;
  font-variant-numeric: tabular-nums;
  margin-top: 8px;
}

.detail-cover-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 4px;
}

.detail-cover-date {
  font-size: 13px;
  font-weight: 400;
  letter-spacing: 1px;
  opacity: 0.75;
}

.detail-cover-fade-bottom {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 90px;
  z-index: 6;
}

/* ============================================================
   无封面主展示区（通用）
   ============================================================ */
.detail-no-cover-logo {
  padding: 80px 0 12px 0;
  display: flex;
  justify-content: center;
}

.detail-logo-img {
  width: 80px; height: auto;
  opacity: 0.8;
}

.detail-no-cover-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8px 24px 12px 24px;
}

.detail-no-cover-main-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.detail-no-cover-days {
  font-size: 120px;
  font-weight: 200;
  line-height: 1;
  letter-spacing: -8px;
  font-variant-numeric: tabular-nums;
  font-family: Georgia, 'Times New Roman', serif;
}

.detail-no-cover-days-label {
  font-size: 32px;
  font-weight: 300;
  letter-spacing: 2px;
  padding-bottom: 6px;
}

.detail-no-cover-hms {
  font-size: 30px;
  font-weight: 200;
  letter-spacing: 2px;
  font-variant-numeric: tabular-nums;
  opacity: 0.55;
  margin-top: 4px;
}

.detail-no-cover-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24px 16px 24px;
  gap: 6px;
}

.detail-no-cover-title {
  font-size: 28px;
  font-weight: 600;
}

.detail-no-cover-date {
  font-size: 16px;
  letter-spacing: 0.5px;
}

.detail-no-cover-sentence-pill {
  margin: 0 24px 16px 24px;
  border-radius: 24px;
  padding: 10px 22px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-no-cover-sentence-text {
  font-size: 17px;
  font-weight: 600;
  letter-spacing: 0.3px;
}

/* ============================================================
   详情信息区（通用）
   ============================================================ */
.detail-info-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24px 16px 24px;
}

.detail-divider {
  width: 40px;
  height: 1.5px;
  margin-bottom: 24px;
  opacity: 0.4;
  /* 由各主题覆盖颜色 */
}

.detail-description-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 0 12px;
}

.detail-main-text {
  font-size: 22px;
  font-weight: 500;
  text-align: center;
  line-height: 1.4;
}

.detail-sub-text {
  font-size: 18px;
  text-align: center;
  max-width: 560rpx;
  line-height: 1.5;
}

.detail-milestone-row {
  margin-top: 18px;
}

.detail-milestone-text {
  font-size: 16px;
}

.detail-elapsed-card {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 16px;
  padding: 12px 24px;
  border-radius: 16px;
  opacity: 0.85;
}

.detail-elapsed-icon {
  font-size: 18px;
}

.detail-elapsed-text {
  font-size: 17px;
  font-weight: 600;
}

/* ============================================================
   底部三按钮（通用）
   ============================================================ */
.detail-bottom-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 28px;
  padding: 20px 24px calc(24px + env(safe-area-inset-bottom, 20px)) 24px;
}

.detail-action-btn {
  padding: 6px 4px;
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-action-btn text {
  font-size: 14px;
}

.action-active {
  font-weight: 600;
}

.detail-action-sep {
  font-size: 14px;
  opacity: 0.35;
}

/* ============================================================
   ★★★ 主题1：🎂 生日 - 暖琥珀 + 金色衬线数字
   ============================================================ */
.cat-birthday {
  /* 背景：温暖琥珀渐变 */
  background: linear-gradient(175deg, #1C0D00 0%, #2A1500 40%, #1A0D00 100%);
}

/* 封面叠加色：暖琥珀 */
.cat-birthday .detail-cover-overlay {
  background: linear-gradient(
    to bottom,
    rgba(26,13,0,0.18) 0%,
    rgba(26,13,0,0.08) 30%,
    rgba(26,13,0,0.52) 65%,
    rgba(26,13,0,0.72) 100%
  );
}

.cat-birthday .detail-cover-fade-top {
  background: linear-gradient(to bottom, rgba(26,13,0,0.38) 0%, rgba(26,13,0,0) 100%);
}

.cat-birthday .detail-cover-fade-bottom {
  background: linear-gradient(to top, #1C0D00 0%, rgba(26,13,0,0) 100%);
}

.cat-birthday .detail-back-arrow { color: rgba(255,228,181,0.9); }
.cat-birthday .detail-edit-text { color: rgba(255,228,181,0.85); text-shadow: 0 1px 4px rgba(0,0,0,0.3); }
.cat-birthday .detail-cover-tag { background: rgba(212,160,23,0.25); }
.cat-birthday .detail-cover-tag-name { color: rgba(255,228,181,0.95); }

/* 封面大数字：暖金色衬线 */
.cat-birthday .detail-cover-days {
  color: #FFE4B5;
  text-shadow: 0 3px 20px rgba(212,160,23,0.5), 0 0 40px rgba(255,200,100,0.2);
}
.cat-birthday .detail-cover-days-label { color: rgba(255,228,181,0.7); }
.cat-birthday .detail-cover-hms { color: rgba(255,228,181,0.55); }
.cat-birthday .detail-cover-title { color: #FFECD2; text-shadow: 0 2px 12px rgba(0,0,0,0.4); }
.cat-birthday .detail-cover-date { color: rgba(255,220,170,0.65); }

/* 无封面区 */
.cat-birthday .detail-no-cover-days { color: #FFE4B5; }
.cat-birthday .detail-no-cover-days-label { color: rgba(212,160,23,0.7); }
.cat-birthday .detail-no-cover-hms { color: rgba(255,228,181,0.5); }
.cat-birthday .detail-no-cover-title { color: #FFECD2; }
.cat-birthday .detail-no-cover-date { color: rgba(255,220,170,0.65); }
.cat-birthday .detail-no-cover-sentence-pill { background: rgba(212,160,23,0.15); }
.cat-birthday .detail-no-cover-sentence-text { color: #D4A017; }

/* 详情区 */
.cat-birthday .detail-divider { background: rgba(212,160,23,0.4); }
.cat-birthday .detail-main-text { color: #FFECD2; }
.cat-birthday .detail-sub-text { color: rgba(255,220,170,0.7); }
.cat-birthday .detail-milestone-text { color: rgba(212,160,23,0.8); }
.cat-birthday .detail-elapsed-card { background: rgba(212,160,23,0.12); }
.cat-birthday .detail-elapsed-text { color: #D4A017; }

/* 底部按钮 */
.cat-birthday .detail-action-btn text { color: rgba(255,220,170,0.7); }
.cat-birthday .action-active { color: #D4A017; }

